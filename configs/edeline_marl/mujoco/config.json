{
    "algo_args": {
        "algo": {
            "batch_size": 16384,
            "buffer_size": 1000000,
            "fixed_order": false,
            "gamma": 0.995,
            "n_step": 20,
            "polyak": 0.01,
            "policy_freq": 1,
            "use_policy_active_masks": true
        },
        "device": {
            "cuda": true,
            "cuda_deterministic": false,
            "torch_threads": 64
        },
        "eval": {
            "eval_episodes": 16,
            "n_eval_rollout_threads": 16,
            "use_eval": true
        },
        "logger": {
            "log_dir": "./results",
            "save_model": true,
            "wandb": true
        },
        "model": {
            "activation_func": "relu",
            "critic_lr": 0.0005,
            "final_activation_func": "tanh",
            "gain": 0.01,
            "hidden_sizes": [128, 128],
            "initialization_method": "orthogonal_",
            "lr": 0.0005,
            "use_feature_normalization": true,
            "log_std_min": -10,
            "log_std_max": 2,
            "entropy_coef": 0.0001
        },
        "render": {
            "render_episodes": 10,
            "use_render": false
        },
        "seed": {
            "seed": 1,
            "seed_specify": true
        },
        "train": {
            "eval_interval": 10000,
            "log_interval": 500,
            "model_dir": null,
            "n_rollout_threads": 16,
            "num_env_steps": 2000000,
            "save_interval": 50000,
            "train_interval": 1,
            "update_per_train": 2,
            "use_linear_lr_decay": false,
            "use_proper_time_limits": true,
            "use_valuenorm": false,
            "warmup_steps": 20000
        },
        "world_model": {
            "balance_coef": 0.0005,
            "dynamics_coef": 20,
            "enc_lr_scale": 0.3,
            "latent_dim": 128,
            "num_bins": 101,
            "num_dynamics_experts": 16,
            "num_enc_layers": 2,
            "num_reward_experts": 16,
            "q_coef": 0.1,
            "reward_coef": 0.1,
            "reward_max": 10,
            "reward_min": -10,
            "scale_tau": 0.01,
            "simnorm_dim": 8,
            "step_rho": 0.5,
            "top_k": 2,
            "use_twohot": true,
            "warmup_train": true,
            "wt_steps": 2500,
            "grad_clip_norm": 20.0,

            "num_cats": 8,
            "cat_dim": 8,
            "sem_dim": 64,
            "hidden_dim": 128,

            "ssm_num_heads": 8,
            "ssm_num_layers": 3,
            "ssm_cross_num_heads": 4,
            "ssm_dropout": 0.1,
            "ssm_ffn_multiplier": 4,

            "flow_steps_train": 8,
            "flow_steps_infer": 1,
            "flow_tau_embed_dim": 64,
            "shortcut_lambda": 0.1,

            "num_experts": 8,
            "num_slots": 1,
            "expert_hidden_dim": 256,
            "num_reward_bins": 51,
            "reward_expert_ffn_hidden": 512,
            "reward_expert_n_heads": 1,
            "reward_expert_dropout": 0.0,
            "reward_head_hidden": 256,
            "continue_hidden_dim": 128,

            "gumbel_tau_start": 1.0,
            "gumbel_tau_end": 0.1,
            "gumbel_anneal_steps": 100000,
            "barlow_twins_lambda": 0.005,
            "aug_dropout": 0.1,

            "accpc_steps_ahead": 3,
            "accpc_temperature": 0.1,

            "loss_weights": {
                "pred": 1.0,
                "rec": 1.0,
                "rep": 0.1,
                "dyn": 1.0,
                "cpc": 0.1,
                "latent": 1.0,
                "flow": 1.0
            }
        },
        "plan": {
            "horizon": 5,
            "iterations": 8,
            "max_std": 1.0,
            "min_std": 0.05,
            "num_elites": 32,
            "num_pi_trajs": 16,
            "num_samples": 512,
            "temperature": 0.5,
            "use_plan": true
        }
    },
    "env_args": {
        "n_agents": 2,
        "n_tasks": 2,
        "episode_limit": 500,
        "envs": {
            "2_cheetah": [
                "run",
                "run_backwards"
            ]
        }
    },
    "main_args": {
        "algo": "edeline_marl",
        "env": "mujoco",
        "exp_name": "edeline_marl_default",
        "load_config": ""
    }
}
